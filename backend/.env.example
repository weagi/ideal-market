# ======================
# 灵感集市 - 环境配置
# ======================

# 服务器配置
NODE_ENV=development
PORT=3001

# 数据库配置 (完整版需要)
MONGODB_URI=mongodb://admin:password123@localhost:27017/ideal_market?authSource=admin
REDIS_URL=redis://localhost:6379

# 安全配置
JWT_SECRET=your-jwt-secret-key-change-in-production

# ======================
# 微信公众号配置
# ======================
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
WECHAT_TOKEN=your-wechat-token
WECHAT_ENCODING_AES_KEY=

# ======================
# AI服务配置
# ======================

# 语音转文字 (ASR) - 支持阿里云、腾讯云、百度等
ASR_PROVIDER=aliyun  # aliyun, tencent, baidu, azure
ASR_API_KEY=your-asr-api-key
ASR_SECRET=your-asr-secret  # 如需要

# 图片OCR识别 - 支持阿里云、腾讯云、百度等  
OCR_PROVIDER=aliyun  # aliyun, tencent, baidu, google
OCR_API_KEY=your-ocr-api-key
OCR_SECRET=your-ocr-secret  # 如需要

# 大语言模型 (LLM) - 支持OpenAI、通义千问、文心一言等
LLM_PROVIDER=qwen  # openai, qwen, wenxin, claude, gemini
LLM_API_KEY=your-llm-api-key
LLM_MODEL=qwen-max  # 根据提供商选择具体模型

# ======================
# 闲鱼集成配置
# ======================
XIANYU_APP_KEY=your-xianyu-app-key  # 如需要API集成

# ======================
# 其他配置
# ======================
UPLOAD_MAX_SIZE=10485760  # 10MB
AI_PROCESSING_TIMEOUT=300000  # 5分钟