<!-- pages/idea-detail/idea-detail.wxml -->
<view class="container">
  <view class="header">
    <text class="title">灵感详情</text>
  </view>
  
  <view class="detail-content" wx:if="{{idea}}">
    <view class="section">
      <text class="section-title">闲鱼标题</text>
      <text class="content-text">{{idea.aiGenerated.xianyuTitle}}</text>
    </view>
    
    <view class="section">
      <text class="section-title">闲鱼详情</text>
      <text class="content-text">{{idea.aiGenerated.xianyuDescription}}</text>
    </view>
    
    <view class="section" wx:if="{{idea.aiGenerated.internalPRD}}">
      <text class="section-title">内部PRD</text>
      <text class="content-text">{{idea.aiGenerated.internalPRD}}</text>
    </view>
    
    <view class="actions" wx:if="{{idea.status === 'completed'}}">
      <button class="action-btn copy-btn" bindtap="copyXianyuContent">一键复制</button>
      <button class="action-btn xianyu-btn" bindtap="goToXianyu">去闲鱼发布</button>
      <button class="action-btn link-btn" bindtap="submitXianyuLink">回填链接</button>
    </view>
    
    <view class="status-info">
      <text class="status-text">状态: 
        <text wx:if="{{idea.status === 'processing'}}" class="processing">处理中</text>
        <text wx:if="{{idea.status === 'completed'}}" class="completed">已完成</text>
        <text wx:if="{{idea.status === 'failed'}}" class="failed">异常</text>
      </text>
      <text class="time-text" wx:if="{{idea.createdAt}}">创建时间: {{idea.createdAt}}</text>
    </view>
  </view>
  
  <view class="loading" wx:elif="{{loading}}">
    <text>加载中...</text>
  </view>
  
  <view class="empty" wx:else>
    <text>灵感不存在</text>
  </view>
</view>