/* pages/idea-detail/idea-detail.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  padding: 40rpx 20rpx;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.detail-content {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 15rpx;
  display: block;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  white-space: pre-wrap;
}

.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  flex-wrap: wrap;
}

.action-btn {
  flex: 1;
  min-width: 200rpx;
  padding: 20rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
}

.copy-btn {
  background: #1890ff;
  color: white;
}

.xianyu-btn {
  background: #fa8c16;
  color: white;
}

.link-btn {
  background: #52c41a;
  color: white;
}

.status-info {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #eee;
}

.status-text, .time-text {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.processing { color: #faad14; }
.completed { color: #52c41a; }
.failed { color: #ff4d4f; }

.loading, .empty {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #666;
}